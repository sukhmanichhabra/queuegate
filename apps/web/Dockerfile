# ──────────────────────────────────────────────────────────────────────────────
# apps/web/Dockerfile — QueueGate Web (Next.js 14)
#
# Uses Next.js `output: 'standalone'` (enabled in next.config.mjs).
# Standalone mode produces .next/standalone/ — a self-contained server bundle
# with only the node_modules actually required at runtime, making the runtime
# image significantly smaller than copying the full monorepo node_modules.
#
# Build context must be the monorepo ROOT. See docker-compose.yml: context: .
# ──────────────────────────────────────────────────────────────────────────────

# ── Stage 1: builder ──────────────────────────────────────────────────────────
FROM node:20-alpine AS builder

WORKDIR /workspace

RUN corepack enable && corepack prepare pnpm@9 --activate

# Copy workspace manifests first for layer-cached pnpm install.
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml tsconfig.base.json ./

COPY apps/api/package.json  ./apps/api/package.json
COPY apps/web/package.json  ./apps/web/package.json

RUN pnpm install --frozen-lockfile

# Copy web source after install to maximise cache hits.
COPY apps/web/app             ./apps/web/app
COPY apps/web/components      ./apps/web/components
COPY apps/web/hooks           ./apps/web/hooks
COPY apps/web/lib             ./apps/web/lib
COPY apps/web/stores          ./apps/web/stores
COPY apps/web/next.config.mjs ./apps/web/next.config.mjs
COPY apps/web/tsconfig.json   ./apps/web/tsconfig.json
COPY apps/web/postcss.config.js   ./apps/web/postcss.config.js
COPY apps/web/tailwind.config.ts  ./apps/web/tailwind.config.ts
COPY apps/web/next-env.d.ts       ./apps/web/next-env.d.ts

# NEXT_PUBLIC_ vars are baked into the browser bundle at build time.
# Use localhost:4000 because this is the HOST-accessible URL — the browser
# making requests to the API will be on the user's machine, not inside the
# Docker network where `api:4000` would be valid.
ARG NEXT_PUBLIC_API_URL=http://localhost:4000
ARG NEXT_PUBLIC_WS_URL=http://localhost:4000
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_WS_URL=$NEXT_PUBLIC_WS_URL

RUN pnpm --filter web run build


# ── Stage 2: runner ───────────────────────────────────────────────────────────
FROM node:20-alpine AS runner

RUN apk add --no-cache curl

WORKDIR /app

# standalone/ contains the minimal server.js + only the node_modules it needs.
COPY --from=builder /workspace/apps/web/.next/standalone ./

# Static assets (.next/static/) must be placed where Next.js expects them
# inside the standalone bundle — under apps/web/.next/static relative to
# the workspace root inside standalone.
COPY --from=builder /workspace/apps/web/.next/static ./apps/web/.next/static

# public/ assets (if any) must also be copied manually in standalone mode.
# Using conditional COPY via shell; this is a no-op if public/ doesn't exist.
COPY --from=builder /workspace/apps/web/public* ./apps/web/public/

EXPOSE 3000

# Simple HTTP check on the root path — Next.js has no built-in /ready endpoint.
# The web service has no direct Postgres/Redis dependencies (it proxies via api),
# so a plain 200 from the homepage is a sufficient liveness signal.
HEALTHCHECK --interval=15s --timeout=5s --start-period=30s --retries=5 \
  CMD curl -f http://localhost:3000/ || exit 1

# Next.js standalone entry point. The server.js is generated by Next.js at
# .next/standalone/apps/web/server.js (monorepo standalone path).
ENV NODE_ENV=production
ENV PORT=3000
ENV HOSTNAME=0.0.0.0

CMD ["node", "apps/web/server.js"]
