{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testMatch": [
    "**/../../test/unit/**/*.test.ts"
  ],
  "roots": [
    "<rootDir>/../../test/unit"
  ],
  "transform": {
    "^.+\\.ts$": ["ts-jest", {
      "tsconfig": "<rootDir>/tsconfig.json"
    }]
  },
  "testEnvironment": "node",
  "testTimeout": 15000
}
