# QueueGate — Environment Variables Template
# Copy this file to apps/api/.env and fill in all values.
# DO NOT commit .env — it is gitignored.
# DO commit this file — it contains no real secrets.
#
# Generate secrets with: openssl rand -hex 32
# All three JWT secrets MUST be different from each other.

# ── Database ──────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/queuegate

# ── Redis ─────────────────────────────────────────────────
# Used by ioredis (direct), BullMQ (queues), and socket.io-redis-adapter
REDIS_URL=redis://localhost:6379

# ── Kafka (optional — app degrades gracefully if Kafka is unavailable) ───────
KAFKA_BROKERS=localhost:9092

# ── JWT Secrets (REQUIRED — app refuses to start if absent or placeholder) ───
#
# Signs HTTP access tokens (15-minute lifetime).
# Generate: openssl rand -hex 32
JWT_ACCESS_SECRET=<generate with: openssl rand -hex 32>

# Signs HTTP refresh tokens (7-day lifetime).
# Must differ from JWT_ACCESS_SECRET.
# Generate: openssl rand -hex 32
JWT_REFRESH_SECRET=<generate with: openssl rand -hex 32>

# Signs short-lived WebSocket ownership tokens (5-minute lifetime).
# Issued by POST /events/:id/join; verified by the WS gateway.
# Must differ from JWT_ACCESS_SECRET and JWT_REFRESH_SECRET.
# Generate: openssl rand -hex 32
JWT_WS_SECRET=<generate with: openssl rand -hex 32>

# ── JWT Expiry (optional — sane defaults apply if omitted) ────────────────────
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Checkout Token ────────────────────────────────────────
# How long (seconds) an admitted user has to complete checkout before expiry.
CHECKOUT_TOKEN_TTL_SECONDS=600

# ── CORS ──────────────────────────────────────────────────
# Comma-separated list of origins allowed by both HTTP and WebSocket CORS.
# When unset or blank, defaults to http://localhost:3000,http://127.0.0.1:3000
# so local dev works with zero config.
#
# When set, OVERRIDES the defaults entirely (does not append).
# Production example:
#   CORS_ORIGINS=https://app.example.com,https://www.example.com
#
# Leave unset for local development.
# CORS_ORIGINS=

# ── Frontend (Next.js) ────────────────────────────────────
# These are exposed to the browser via NEXT_PUBLIC_ prefix.
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=http://localhost:4000
