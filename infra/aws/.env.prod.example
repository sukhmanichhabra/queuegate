# ──────────────────────────────────────────────────────────────────────────────
# QueueGate — Production Environment Variables (AWS)
# Copy this to: /opt/queuegate/.env.prod
# NEVER commit .env.prod to git.
#
# Generate all secrets with: openssl rand -hex 32
# All three JWT secrets MUST be different.
# ──────────────────────────────────────────────────────────────────────────────

# ── Your Domain ───────────────────────────────────────────────────────────────
# Used in Caddy config and CORS settings.
# Example: queuegate.yourdomain.com
DOMAIN=queuegate.yourdomain.com

# ── Database (internal Docker network — do NOT change host) ───────────────────
POSTGRES_USER=queuegate
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
POSTGRES_DB=queuegate
DATABASE_URL=postgresql://queuegate:REPLACE_WITH_STRONG_PASSWORD@postgres:5432/queuegate

# ── Redis (internal Docker network) ───────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Kafka (internal Docker network, KRaft single broker) ──────────────────────
KAFKA_BROKERS=kafka:29092

# ── JWT Secrets (REQUIRED) ────────────────────────────────────────────────────
# Run: openssl rand -hex 32
JWT_ACCESS_SECRET=REPLACE_WITH_OPENSSL_RAND_HEX_32
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_OPENSSL_RAND_HEX_32
JWT_WS_SECRET=REPLACE_WITH_ANOTHER_OPENSSL_RAND_HEX_32

# ── JWT Expiry ────────────────────────────────────────────────────────────────
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Checkout ──────────────────────────────────────────────────────────────────
CHECKOUT_TOKEN_TTL_SECONDS=600

# ── CORS (must match your real domain) ───────────────────────────────────────
# This OVERRIDES the default localhost values — must be set for production.
# Include https:// and no trailing slash.
CORS_ORIGINS=https://queuegate.yourdomain.com

# ── Frontend (Next.js — baked into browser bundle at build time) ──────────────
# The browser connects to these URLs from the user's machine.
# Set to your public HTTPS domain + /api path prefix (Caddy routes /api/* → api:4000)
NEXT_PUBLIC_API_URL=https://queuegate.yourdomain.com/api
NEXT_PUBLIC_WS_URL=https://queuegate.yourdomain.com

# ── Node.js memory caps (important on t2.micro 1GB) ──────────────────────────
# Applied via NODE_OPTIONS in docker-compose.prod.yml — do not change here.
# API_NODE_OPTIONS=--max-old-space-size=200
# WEB_NODE_OPTIONS=--max-old-space-size=200
